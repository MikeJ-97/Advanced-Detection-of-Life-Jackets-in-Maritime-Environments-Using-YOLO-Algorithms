# --- Claude Code session artefacts ---
.remember/
.claude/

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# --- TensorFlow Object Detection API artefacts ---
# TFRecords embed dataset images — regenerate from Custom_dataset/ instead
*.record

# Intermediate XML→CSV label files — useless without the (excluded) XML labels
Trained_weights/**/data/*.csv

# TensorBoard event logs (contain VM hostnames, no reproducibility value)
events.out.tfevents.*

# Intermediate training checkpoints — keep only model/saved_model/ as the exported artefact
Trained_weights/**/training/ckpt-*
Trained_weights/**/training/checkpoint
Trained_weights/**/model/checkpoint/

# Duplicates of Custom_dataset/ already inside Trained_weights/*/data/
Trained_weights/**/data/images/
Trained_weights/**/data/train_labels/
Trained_weights/**/data/val_labels/
Trained_weights/**/data/test_labels/

# --- YOLO (Ultralytics) training-output bloat ---
# Keep ONLY weights/best.pt under each Yolov* (and its exp*/ subdir for YOLOv7).
# Exclude epoch checkpoints, last.pt, init.pt, and crash-recovery snapshots.
Trained_weights/Yolov*/weights/*
!Trained_weights/Yolov*/weights/best.pt
Trained_weights/Yolov*/exp*/weights/*
!Trained_weights/Yolov*/exp*/weights/best.pt

# Per-batch training/val visualisation dumps — ship-noise
Trained_weights/Yolov*/train_batch*.jpg
Trained_weights/Yolov*/val_batch*.jpg
Trained_weights/Yolov*/exp*/train_batch*.jpg
Trained_weights/Yolov*/exp*/val_batch*.jpg

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/
